# Ignore Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environments
venv/
env/
ENV/
.venv/

# Ignore environment/config files
.env
.env.*
*.env

# Ignore OS and editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/

# Ignore Git and metadata
.git
.gitignore

# Ignore test and temp files
*.log
*.tmp
*.swp
*.swo
*.bak
tmp/
temp/

# Ignore local video/audio files
*.mp3
*.mp4
*.wav
*.webm
*.avi
*.mov

# Ignore build artifacts
build/
dist/
*.egg-info/

# Ignore Jupyter notebooks
.ipynb_checkpoints

# Ignore coverage and test reports
.coverage
.tox/
.pytest_cache/
.cache/
nosetests.xml
coverage.xml

# Ignore docker config artifacts (optional)
docker-compose.override.yml
